# fmt_sim.db: REDIT : Row EDIT

record(longout, "${UUT}:FMT_SIM:REDIT:ROW")
{
	field(DTYP, "asynInt32")
	field(OUT,  "@asyn($(PORT),$(ADDR),$(TIMEOUT))FMT_REDIT_ROW")
	field(PINI, "YES")
	field(VAL,  "0")
	info(Q:group, {
		"${UUT}:FMT_SIM:REDIT": {
			"ROW": {+channel:"VAL"}
		}
	})
}
