	field(DTYP, "asynOctetRead")
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))REDIS_MMKEY")
	field(SCAN, "I/O Intr")
	field(DESC, "Latest Major/Minor (UUT/Timestamp) key")
	
	info(Q:group, {
