record(longout, "${UUT}:SOE_HLD:TAB:Save") {
    field(MDEL, "-1") # ensure we always trigger group monitor
    field(TPRO, "1")
    info(Q:group, {
	"${UUT}:SOE_HLD:TAB:Tbl":{
	    "_save":{+type:"proc",
		     +channel:"VAL",
		     +putorder:15,
		     +trigger:"*"}
	}
    })
}

