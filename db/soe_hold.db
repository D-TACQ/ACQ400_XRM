record(waveform, "${UUT}:SOE_HLD" ){
	field(DTYP, "asynInt32ArrayIn")
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))SOE_HLD_TABLE_WF")
	field(FTVL, "LONG")
	field(SCAN, "I/O Intr")
	field(NELM, "6400")            # biggest possible.
	field(DESC, "RAW hold buffer")
}

record(waveform, "${UUT}:SOE_HLD:TAB:Labels_") {
	field(FTVL, "STRING")
	field(NELM, "15")
	field(INP , {const:["Row", "PV_ID", "CLIDAT", "TIMESTAMP",
	                    "AI1", "AI2", "DI1", "DI2",
	                    "SP0/SMPL", "SP1/US", "SP2/WRV", "SP3/WRSE", "WRVS", "WRVT", "WRUS" ]})
	info(Q:group, {
		"${UUT}:SOE_HLD:TAB:Tbl":{
			+id:"epics:nt/NTTable:1.0",
			"labels":{+type:"plain", +channel:"VAL"}
		}
	})
	field(TPRO, "1")
}

record(waveform, "${UUT}:SOE_HLD:TAB:ROWNUM")
{
	field(DTYP, "asynInt8ArrayIn")
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))SOE_HLD_COL_ROWNUM")
	field(FTVL, "UCHAR")
	field(NELM, "64")
	field(SCAN, "I/O Intr")
	info(Q:group, {
		"${UUT}:SOE_HLD:TAB:Tbl": {
			"value.ROWNUM": {+type:"plain", 
					 +channel:"VAL", +putorder:0 }
		}
	})
}

