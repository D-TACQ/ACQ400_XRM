# soe_base : Sample On Event

record(bo, "${UUT}:SOE:RUNSTOP")
{
	field(PINI, "YES")
	field(DTYP, "asynInt32")
	field(OUT,  "@asyn($(PORT),$(ADDR),$(TIMEOUT))RUNSTOP")
	field(SCAN, "Passive")
	field(ZNAM, "STOP")
	field(ONAM, "RUN")
	field(VAL,  "0")
}
record(longin, "${UUT}:SOE:UPDATES")
{
	field(PINI, "NO")
	field(DTYP, "asynInt32")
	field(INP,  "@asyn($(PORT),$(ADDR),$(TIMEOUT))UPDATES")
	field(SCAN, "I/O Intr")
	field(TSE,  "-2")
}

record(longin, "${UUT}:SOE:FMT_RX_TIMEOUTS")
{
	field(PINI, "NO")
	field(DTYP, "asynInt32")
	field(INP,  "@asyn($(PORT),$(ADDR),$(TIMEOUT))SOE_FMT_RX_TIMEOUTS")
	field(SCAN, "I/O Intr")
	field(TSE,  "-2")

	field(DESC, "Data buffer is waiting but FMT no show")
}

record(longin, "${UUT}:SOE:FMT_RX_SUCCESS")
{
	field(PINI, "NO")
	field(DTYP, "asynInt32")
	field(INP,  "@asyn($(PORT),$(ADDR),$(TIMEOUT))SOE_FMT_RX_SUCCESS")
	field(SCAN, "I/O Intr")
	field(TSE,  "-2")

	field(DESC, "Data buffer is waiting but FMT no show")
}

record(int64in, "${UUT}:SOE:TS_USEC")
{
	field(PINI, "NO")
	field(DTYP, "asynInt64")
	field(INP,  "@asyn($(PORT),$(ADDR),$(TIMEOUT))TS_USEC")
	field(SCAN, "I/O Intr")
	field(TSE,  "-2")
}

record(longin, "${UUT}:SOE:KBUF:INDEX")
{
	field(PINI, "NO")
	field(DTYP, "asynInt32")
	field(INP,  "@asyn($(PORT),$(ADDR),$(TIMEOUT))SOE_KBUF_INDEX")
	field(SCAN, "I/O Intr")
	field(TSE,  "-2")
	info(Q:group, {
		"${UUT}:SOE:KBUF": {
			"INDEX": {+channel:"VAL"}
		}
	})
	field(DESC, "current buffer number")
}
record(int64in, "${UUT}:SOE:KBUF:WRT0")
{
	field(PINI, "NO")
	field(DTYP, "asynInt64")
	field(INP,  "@asyn($(PORT),$(ADDR),$(TIMEOUT))SOE_KBUF_WRT0")
	field(SCAN, "I/O Intr")
	field(TSE,  "-2")
	info(Q:group, {
		"${UUT}:SOE:KBUF": {
			"WRT0": {+channel:"VAL"}
		}
	})
	field(DESC, "start time in buffer")
}
record(int64in, "${UUT}:SOE:KBUF:WRT1")
{
	field(PINI, "NO")
	field(DTYP, "asynInt64")
	field(INP,  "@asyn($(PORT),$(ADDR),$(TIMEOUT))SOE_KBUF_WRT1")
	field(SCAN, "I/O Intr")
	field(TSE,  "-2")
	info(Q:group, {
		"${UUT}:SOE:KBUF": {
			"WRT1": {+channel:"VAL"}
		}
	})
	field(DESC, "end time in buffer")
}


record(waveform, "${UUT}:SOE_LUT:TAB:Labels_") {
	field(FTVL, "STRING")
	field(NELM, "5")
	field(INP , {const:["Row", "Event", "Pad", "PV_ID", "OFFSET_US"]})
	info(Q:group, {
		"${UUT}:SOE_LUT:TAB:Tbl":{
			+id:"epics:nt/NTTable:1.0",
			"labels":{+type:"plain", +channel:"VAL"}
		}
	})
	field(TPRO, "1")
}

record(waveform, "${UUT}:SOE_LUT:TAB:ROWNUM")
{
	field(DTYP, "asynInt8ArrayIn")
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))SOE_LUT_COL_ROWNUM")
	field(FTVL, "UCHAR")
	field(NELM, "64")
	field(SCAN, "I/O Intr")
	info(Q:group, {
		"${UUT}:SOE_LUT:TAB:Tbl": {
			"value.ROWNUM": {+type:"plain", 
					 +channel:"VAL", +putorder:0 }
		}
	})
}

record(waveform, "${UUT}:SOE_LUT:TAB:EVENT")
{
	field(DTYP, "asynInt16ArrayIn")
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))SOE_LUT_COL_EVENT")
	field(FTVL, "USHORT")
	field(NELM, "64")
	field(SCAN, "I/O Intr")
	info(Q:group, {
		"${UUT}:SOE_LUT:TAB:Tbl": {
			"value.EVENT": {+type:"plain", 
					+channel:"VAL", +putorder:1 }
		}
	})
}

