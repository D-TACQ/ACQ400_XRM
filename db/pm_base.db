# pm_base : Post Mortem

record(bo, "${UUT}:PM:RUNSTOP")
{
	field(PINI, "YES")
	field(DTYP, "asynInt32")
	field(OUT,  "@asyn($(PORT),0,$(TIMEOUT))RUNSTOP")
	field(SCAN, "Passive")
	field(ZNAM, "STOP")
	field(ONAM, "RUN")
	field(VAL,  "0")
}
record(longin, "${UUT}:PM:UPDATES")
{
	field(PINI, "NO")
	field(DTYP, "asynInt32")
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))UPDATES")
	field(SCAN, "I/O Intr")
	field(TSE,  "-2")
}

record(longout, "${UUT}:PM:NBUF")
{
	field(PINI, "YES")
	field(DTYP, "asynInt32")
	field(OUT,  "@asyn($(PORT),0,$(TIMEOUT))NBUF")
	field(VAL,  "20")
}

record(int64in, "${UUT}:PM:TS_USEC")
{
	field(PINI, "NO")
	field(DTYP, "asynInt64")
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))TS_USEC")
	field(SCAN, "I/O Intr")
	field(TSE,  "-2")
}





