# proxies for SSB records. Sample definition grouped as ${UUT}:SMPL

record (longout, "${UUT}:0:SSB") {
# all ${SITE}:SSB instantiated at the end, only :0: is in the GROUP
	
	info(Q:group, {
		"${UUT}:SMPL": {
			"SSB": {+channel:"VAL"}
		}
	})
	field(DESC, "Sample Size in Bytes")
}


record (longin, "${UUT}:SOE:SMPL_AI_COUNT") {
	field(DTYP, "asynInt32")
	
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))SOE_SMPL_AI_COUNT")
	field(SCAN, "I/O Intr")
	info(Q:group, {
		"${UUT}:SMPL": {
			"AI_COUNT": {+channel:"VAL"}
		}
	})
	field(DESC, "# AI16 elements in sample")
}

record (longout, "${UUT}:SOE:SMPL_AI_INDEX") {
	field(DTYP, "Soft Channel")
	field(VAL,  "0")
	field(PINI, "YES")
	
	info(Q:group, {
		"${UUT}:SMPL": {
			"AI_INDEX": {+channel:"VAL"}
		}
	})
	field(DESC, "index in LW to first AI16 in sample")
}	
# SMPL_AI_INDEX: ALWAYS ZERO!

