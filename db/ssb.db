# proxies for SSB records.


record (stringout,  "${UUT}:0:AGGREGATOR:SITES") {
	field(DTYP, "asynOctetWrite")
	field(OUT,  "@asyn($(PORT),0,$(TIMEOUT))SOE_AGG_SITES")
	field(DOL,  "${ACQ400IOC}:0:AGGREGATOR:SITES CP")
	field(OMSL, "closed_loop")
}

record (longout, "${UUT}:${SITE}:SSB") {
	field(DTYP, "asynInt32")
	field(OUT,  "@asyn($(PORT),${SITE},$(TIMEOUT))SOE_SITE_SSB")
	field(DOL, "${SRPV} CP")

	field(OMSL, "closed_loop")
}

record (longout, "${UUT}:${SITE}:IS_ADC") {
	field(DTYP, "asynInt32")
	field(OUT,  "@asyn($(PORT),${SITE},$(TIMEOUT))SOE_SITE_IS_ADC")
	field(DOL, "${ACQ400IOC}:${SITE}:IS_ADC CP")
	field(OMSL, "closed_loop")
}

record (longin, "${UUT}:AGG:SPAD:N") {
	field(DTYP, "asynInt32")
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))SOE_SMPL_SP_COUNT")
	field(DESC, "# SPAD entries")
}

record (longin, "${UUT}:SOE:SMPL_AI_COUNT") {
	field(DTYP, "asynInt32")
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))SOE_SMPL_AI_COUNT")
	field(SCAN, "I/O Intr")
}

record (longin, "${UUT}:SOE:SAMPLE_DI_INDEX") {
	field(DTYP, "asynInt32")
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))SOE_SMPL_DI_INDEX")
	field(SCAN, "I/O Intr")
}

record (longin, "${UUT}:SOE:SMPL_DI_COUNT") {
	field(DTYP, "asynInt32")
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))SOE_SMPL_DI_COUNT")
	field(SCAN, "I/O Intr")
}

record (longin, "${UUT}:SOE:SAMPLE_SP_INDEX") {
	field(DTYP, "asynInt32")
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))SOE_SMPL_SP_INDEX")
	field(SCAN, "I/O Intr")
}

record (longin, "${UUT}:SOE:SMPL_SP_COUNT") {
	field(DTYP, "asynInt32")
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))SOE_SMPL_SP_COUNT")
	field(SCAN, "I/O Intr")
}


