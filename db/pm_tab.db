record(longout, "${UUT}:PM:TAB:Save") {
    field(MDEL, "-1") # ensure we always trigger group monitor
    field(TPRO, "1")
    info(Q:group, {
	"${UUT}:PM:TAB:Tbl":{
	    "_save":{+type:"proc",
		     +channel:"VAL",
		     +putorder:10,
		     +trigger:"*"}
	}
    })
}

