record(waveform, "${UUT}:PM:TAB:Labels_") {
	field(FTVL, "STRING")
	field(NELM, "11")
	field(INP , {const:["Row", "Live Buf", "PM Buf", "TIMESTAMP",
			    "SP0/SMPL", "SP1/US", "SP2/WRV", "SP3/WRSE", "WRVS", "WRVT", "WRUS" ]})
	info(Q:group, {
		"${UUT}:PM:TAB:Tbl":{
			+id:"epics:nt/NTTable:1.0",
			"labels":{+type:"plain", +channel:"VAL"}
		}
	})
	field(TPRO, "1")
}

record(waveform, "${UUT}:PM:TAB:ROWNUM")
{
	field(DTYP, "asynInt8ArrayIn")
	field(INP,  "@asyn($(PORT),0,$(TIMEOUT))PM_COL_ROWNUM")
	field(FTVL, "UCHAR")
	field(NELM, "${ROWS}")
	field(SCAN, "I/O Intr")
	info(Q:group, {
		"${UUT}:PM:TAB:Tbl": {
			"value.ROWNUM": {+type:"plain", 
					 +channel:"VAL", +putorder:0 }
		}
	})
}

