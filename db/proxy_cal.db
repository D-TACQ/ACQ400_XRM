record(waveform, "${UUT}:${SITE}:AI:CAL:ESLO") {
	field(DTYP, "asynFloat32ArrayIn")
	field(INP,  "@asyn($(PORT),$(ADDR),$(TIMEOUT))AI_CAL_ESLO")
	field(NELM, "${nchanp1}")
	field(FTVL, "FLOAT")
	field(DESC, "Slope each channel 1..N, index from 0")
}

record(waveform, "${UUT}:${SITE}:AI:CAL:EOFF") {
	field(DTYP, "asynFloat32ArrayIn")
	field(INP,  "@asyn($(PORT),$(ADDR),$(TIMEOUT))AI_CAL_EOFF")
	field(NELM, "${nchanp1}")
	field(FTVL, "FLOAT")
	field(DESC, "Offset each channel 1..N, index from 0")	
}

