#!/bin/sh

SPORT=FMTS
SRC=WRTS
echo acq400_FMT_SimConfigure\($SPORT,$SRC\)
PRAMS="UUT=${IOC_HOST},PORT=$SPORT,ADDR=0,TIMEOUT=0"
echo dbLoadRecords\(\"db/acq400_asyn_base.db\",\"${PRAMS},FUN=FMT\"\)
echo dbLoadRecords\(\"db/fmt_base.db\",\"${PRAMS}\"\)
echo dbLoadRecords\(\"db/fmt_sim.db\",\"${PRAMS}\"\)